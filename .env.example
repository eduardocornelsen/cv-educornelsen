# =============================================================================
# ENVIRONMENT VARIABLES — copy this file to .env and fill in your values.
# NEVER commit .env to git. It is listed in .gitignore.
# In production (Cloud Run), set these in the GCP console or via Secret Manager.
# =============================================================================

# --- Gemini API (AI Chatbot) -------------------------------------------------
# Your Google Gemini API key. Used by the Express backend to call the chatbot.
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- LangFuse (Chatbot Observability & Tracing) ------------------------------
# Traces every chatbot conversation so you can inspect cost, latency, and safety.
# Create a free account at: https://langfuse.com → New Project → copy the keys.
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- App URL (build-time, injected by Vite) ----------------------------------
# The public URL where your site is served.
# Local dev: http://localhost:5173
# Production: https://your-domain.com
VITE_APP_URL=http://localhost:5173

# --- Server Port -------------------------------------------------------------
# The port the Express server listens on. Cloud Run expects 8080.
PORT=8080
